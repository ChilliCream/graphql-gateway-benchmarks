<Project Sdk="Microsoft.NET.Sdk.Web">

  <!-- Generated by install.sh when BENCH_GATEWAY_DOTNET=11 (the fusion-nightly-net11
       build) to retarget the gateway to .NET 11 and opt into runtime-async. Absent
       for the .NET 10 builds (fusion, fusion-nightly), which stay on net10.0
       (TargetFramework from composite-schema/Directory.Build.props). -->
  <Import Project="bench.props" Condition="Exists('bench.props')" />

  <PropertyGroup>
    <RootNamespace>eShop.Gateway</RootNamespace>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="HotChocolate.AspNetCore.Pipeline" Version="16.1.3" />
    <PackageReference Include="HotChocolate.Fusion.AspNetCore" Version="16.1.3" />
    <PackageReference Include="HotChocolate.Fusion.Execution.Types" Version="16.1.3" />
    <PackageReference Include="HotChocolate.Fusion.Execution" Version="16.1.3" />
    <PackageReference Include="Microsoft.AspNetCore.HeaderPropagation" Version="10.0.6" />
  </ItemGroup>

</Project>
